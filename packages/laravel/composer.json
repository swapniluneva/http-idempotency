{
    "name": "httpidempotency/laravel",
    "description": "Laravel middleware implementing the IETF Idempotency-Key HTTP header draft.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "idempotency", "middleware", "idempotency-key", "rfc9457"],
    "homepage": "https://github.com/swapniluneva/http-idempotency",
    "authors": [
        {
            "name": "Swapnil Srivastava",
            "email": "srivastava.swapnil99@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/swapniluneva/http-idempotency/issues",
        "source": "https://github.com/swapniluneva/http-idempotency"
    },
    "require": {
        "php": ">=8.2",
        "httpidempotency/core": "^0.1",
        "nyholm/psr7": "^1.8",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/http": "^11.0 || ^12.0",
        "illuminate/database": "^11.0 || ^12.0",
        "illuminate/console": "^11.0 || ^12.0",
        "illuminate/contracts": "^11.0 || ^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "phpstan/phpstan": "^1.11"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core",
            "options": { "symlink": true }
        }
    ],
    "autoload": {
        "psr-4": {
            "HttpIdempotency\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HttpIdempotency\\Laravel\\Tests\\": "tests/",
            "HttpIdempotency\\Tests\\": "../core/tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "HttpIdempotency\\Laravel\\IdempotencyServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
