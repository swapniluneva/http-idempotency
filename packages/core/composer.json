{
    "name": "httpidempotency/core",
    "description": "Framework-agnostic implementation of the IETF Idempotency-Key HTTP header draft (PSR-7/PSR-15).",
    "type": "library",
    "license": "MIT",
    "keywords": ["idempotency", "http", "psr-15", "rfc9457", "idempotency-key"],
    "homepage": "https://github.com/swapniluneva/http-idempotency",
    "authors": [
        {
            "name": "Swapnil Srivastava",
            "email": "srivastava.swapnil99@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/swapniluneva/http-idempotency/issues",
        "source": "https://github.com/swapniluneva/http-idempotency"
    },
    "require": {
        "php": ">=8.2",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/http-factory": "^1.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "phpstan/phpstan": "^1.11",
        "nyholm/psr7": "^1.8",
        "phpbench/phpbench": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "HttpIdempotency\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HttpIdempotency\\Tests\\": "tests/",
            "HttpIdempotency\\Benchmarks\\": "benchmarks/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "bench": "phpbench run --report=default"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpbench/phpbench": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
